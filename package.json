{
  "name": "@privchat/react",
  "version": "0.0.0",
  "description": "Headless React integration layer for @privchat/sdk — Provider, hooks, ViewModels. No visuals, no router, no multi-tab policy.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@privchat/sdk": "*",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@privchat/sdk": "file:../privchat-sdk-typescript",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "keywords": [
    "privchat",
    "react",
    "im",
    "instant-messaging",
    "headless"
  ]
}
